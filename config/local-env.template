# Local development defaults only. Copy values into your private shell/profile as needed.
AGENT_SUPPORT_SERVICE_NAME=Agent Support
AGENT_SUPPORT_SERVICE_VERSION=0.1.0
AGENT_SUPPORT_ENVIRONMENT=local
AGENT_SUPPORT_ADMIN_TOKEN=local-admin-token # pragma: allowlist secret
AGENT_SUPPORT_INTERNAL_TOKEN=local-internal-token # pragma: allowlist secret
AGENT_SUPPORT_ADAPTER_TOKEN=local-adapter-token # pragma: allowlist secret
AGENT_SUPPORT_ADAPTER_CREDENTIAL_ID=local-telegram-sandbox
AGENT_SUPPORT_ADAPTER_PLATFORM=telegram
AGENT_SUPPORT_ADAPTER_EXTERNAL_WORKSPACE_ID=sandbox-workspace
AGENT_SUPPORT_ADAPTER_EXTERNAL_CHANNEL_ID=*
AGENT_SUPPORT_DATABASE_ADMIN_URL=postgresql+psycopg://agent_support_admin:agent_support_admin@localhost:5432/agent_support # pragma: allowlist secret
AGENT_SUPPORT_DATABASE_URL=postgresql+psycopg://agent_support_app:agent_support_app@localhost:5432/agent_support # pragma: allowlist secret
AGENT_SUPPORT_REDIS_URL=redis://localhost:6379/0
AGENT_SUPPORT_REDIS_STREAM_MAX_LENGTH=100000
AGENT_SUPPORT_REDIS_PUBLISH_TIMEOUT_SECONDS=1.0
AGENT_SUPPORT_REDIS_MEMORY_WARN_RATIO=0.80
AGENT_SUPPORT_REDIS_MEMORY_REJECT_RATIO=0.90
AGENT_SUPPORT_REDIS_PENDING_REJECT_LIMIT=10000
AGENT_SUPPORT_REDIS_PENDING_IDLE_RECLAIM_SECONDS=300
AGENT_SUPPORT_REDIS_INGRESS_CONSUMER_GROUP=message-stub
AGENT_SUPPORT_REDIS_RECLAIM_IDLE_MILLIS=300000
AGENT_SUPPORT_REDIS_RECLAIM_RETRY_LIMIT=3
AGENT_SUPPORT_REDIS_RECLAIM_BATCH_SIZE=10
AGENT_SUPPORT_REDIS_DLQ_MAX_LENGTH=10000
AGENT_SUPPORT_REDIS_TEXT_PREVIEW_MAX_CHARS=500
AGENT_SUPPORT_REDIS_CONSUMER_BLOCK_MS=5000
AGENT_SUPPORT_REDIS_CONSUMER_BATCH_SIZE=10
AGENT_SUPPORT_REDIS_CONNECTION_POOL_SIZE=10
AGENT_SUPPORT_QDRANT_URL=http://localhost:6333

# Telegram sandbox adapter. Keep real bot token private.
TELEGRAM_BOT_TOKEN=
TELEGRAM_EXTERNAL_WORKSPACE_ID=sandbox-workspace
TELEGRAM_OUTBOUND_STREAM=local:<tenant_id>:outbound:telegram
TELEGRAM_OUTBOUND_GROUP=telegram-sandbox
TELEGRAM_OUTBOUND_CONSUMER=telegram-sandbox-1
